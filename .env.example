# Local development environment variables.
# Copy this file to .env.local and fill in values for the DEV Supabase project.
# .env.local is gitignored — never commit it.
#
# For EAS builds, do not put values here.
# Set per-environment values via the EAS dashboard or:
#   eas env:create --scope project --environment development
#   eas env:create --scope project --environment preview
#   eas env:create --scope project --environment production
#
# The mobile app never selects Plaid or Dwolla environment.
# Each Supabase project controls its own financial environment through
# server-side Edge Function secrets (PLAID_ENV, DWOLLA_ENV).

EXPO_PUBLIC_SUPABASE_URL=
EXPO_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
